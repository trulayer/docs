#!/usr/bin/env bash
# pre-push: runs on every `git push`. Blocks the push on any failure.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

fail() { echo "❌ $*" >&2; exit 1; }
step() { echo "▶ $*"; }

step "docs: broken link check"
pnpm broken-links || fail "broken links found"

echo "✅ pre-push checks passed"
